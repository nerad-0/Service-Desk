@baseUrl = http://localhost/servisdesk/public/api/index.php
@csrf = paste-csrf-token-here

### Health
GET {{baseUrl}}/health
Accept: application/json

### Login as admin
POST {{baseUrl}}/auth/login
Content-Type: application/json
Accept: application/json

{
  "email": "admin@servisdesk.local",
  "password": "password"
}

### Current user
GET {{baseUrl}}/auth/me
Accept: application/json

### List tickets
GET {{baseUrl}}/tickets?page=1&per_page=10
Accept: application/json

### Create ticket
POST {{baseUrl}}/tickets
Content-Type: application/json
Accept: application/json
X-CSRF-Token: {{csrf}}

{
  "title": "Testovací požadavek z REST klienta",
  "description": "Tento požadavek slouží pro ověření API endpointu.",
  "category_id": 1,
  "priority": "medium"
}

### Dashboard
GET {{baseUrl}}/admin/dashboard
Accept: application/json

### Logout
POST {{baseUrl}}/auth/logout
Content-Type: application/json
Accept: application/json
X-CSRF-Token: {{csrf}}

{}

